# ============================================================
# LPD Canggu — Environment Configuration
# Salin file ini ke .env dan sesuaikan nilainya
# ============================================================

# ---- Mode Database ----
# Pilih: sqlite (default/lokal) atau sqlsrv (SQL Server/produksi)
DB_CONNECTION=sqlite

# ---- SQLite (aktif jika DB_CONNECTION=sqlite) ----
# Path absolut ke file database SQLite
SQLITE_PATH=/FULL/PATH/ke/lpd-canggu/data/lpd_canggu.sqlite

# ---- SQL Server (aktif jika DB_CONNECTION=sqlsrv) ----
DB_HOST=localhost
DB_PORT=1433
DB_DATABASE=Giosoft_LPD
DB_USERNAME=sa
DB_PASSWORD=#sa.lpd.Canggu.21

# ---- Aturan Transaksi ----
SALDO_MIN=50000        # Saldo minimum mengendap (Rp)
MIN_TRANSFER=10000     # Minimum nominal transfer (Rp)
MAX_TRANSFER=5000000   # Maksimum nominal transfer (Rp)
